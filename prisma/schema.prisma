generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Property {
  id          String   @id @default(cuid())
  title       String
  price       Float
  location    String
  type        String   // piso, casa, local, terreno, oficina
  status      String   @default("disponible") // disponible, reservado, vendido
  description String
  images      String   // JSON array as string
  fotocasaUrl String?
  bedrooms    Int?
  bathrooms   Int?
  sqMeters    Float?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
