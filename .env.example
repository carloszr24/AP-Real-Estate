# Supabase → Project Settings → Database
#
# DATABASE_URL: "Connection pooling" → URI → modo Transaction (puerto 6543).
#   Añade al final si no viene: ?pgbouncer=true
# DIRECT_URL: "Connection string" directa (puerto 5432) para migraciones y Prisma Studio.
#
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Panel /admin — solo servidor (nunca NEXT_PUBLIC_*)
ADMIN_PASSWORD="cambia-esto"
